---
import "@astrojs/starlight/style/markdown.css"

const { lang  } = Astro.props;
const { entry } = Astro.locals.starlightRoute;
const { publishDate, updateDate, displayPublishDate = true, wide } = entry.data;
const isWide = !!wide;
---

{ (publishDate || updateDate) && displayPublishDate &&
    <p>
        {publishDate && <>
			{Astro.locals.t('page.publishDate')}{' '}
			<time datetime={publishDate.toISOString()}>
				{publishDate.toLocaleDateString(lang, { dateStyle: 'medium', timeZone: 'UTC' })}
			</time>
        </>}
        {publishDate && updateDate && <br>}
        {updateDate && <>
			{Astro.locals.t('page.lastUpdated')}{' '}
			<time datetime={updateDate.toISOString()}>
				{updateDate.toLocaleDateString(lang, { dateStyle: 'medium', timeZone: 'UTC' })}
			</time>
        </>}
    </p>
}

{isWide && (
    <style is:global>
        /* Increase width and set tiny 1rem padding for title and content panels */
        .main-pane .content-panel {
            --sl-content-width: 100% !important;
            padding-inline: 1rem !important;
        }

        /* Ensure markdown content fills the available width */
        .sl-markdown-content {
            max-width: 100% !important;
        }

        /* Ensure the article doesn't have a max-width constraint */
        article {
            max-width: 100% !important;
        }
    </style>
)}

<div class="sl-markdown-content"><slot /></div>